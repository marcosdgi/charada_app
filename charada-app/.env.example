# Environment variables
# Copiar a .env y rellenar; .env no se commitea.

# App Configuration
EXPO_PUBLIC_APP_NAME=2048 Puzzle
EXPO_PUBLIC_APP_VERSION=1.0.0

# API (alineado con Postman: base_url_local, base_url_prod)
# Opción 1: una sola URL según el entorno donde corres la app
EXPO_PUBLIC_API_BASE_URL=http://localhost:3333

# Opción 2: definir ambas; la app usa LOCAL en dev y PROD en release
EXPO_PUBLIC_API_BASE_URL_LOCAL=http://localhost:3333
EXPO_PUBLIC_API_BASE_URL_PROD=https://charadaapp-production.up.railway.app/api/v1

EXPO_PUBLIC_API_TIMEOUT=15000

# id (Postman) - rolId por defecto en registro
EXPO_PUBLIC_DEFAULT_ROL_ID=1
